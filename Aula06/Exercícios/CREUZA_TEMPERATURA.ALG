Algoritmo "Creuza_temperatura"

Var
   temp, cel, far :real
Inicio
   escreval("Qual a temperatura atual Creuza ?")
   leia(cel)
   escreval("Creuza,vocę está nos EUA,a medida é em Farenheit,vamos converter ?")
   far <-(cel * 9 / 5) + 32
   
   escreval("A temperatura atual é ",far:4:1)
Fimalgoritmo